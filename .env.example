# App
NEXT_PUBLIC_PRODUCT_NAME="Provenance"
NEXT_PUBLIC_SITE_TITLE="Provenance | A Journal of Art, Objects & Their Histories"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_AUTH_PASSWORD=true
NEXT_PUBLIC_AUTH_MAGIC_LINK=true
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true

# Supabase (from Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (from https://dashboard.stripe.com/apikeys and Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: for Stripe.js / Elements (Checkout works without it)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs — use the Stripe Price ID (starts with price_xxx), NOT the dollar amount.
# Create Products & Prices in Stripe Dashboard, then copy each Price ID.
# Artist: $10/mo, $99/yr | Collector: $29.99/mo, $299.90/yr | Gallery: $99/mo, $990/yr
STRIPE_PRICE_ARTIST_MONTHLY=
STRIPE_PRICE_ARTIST_YEARLY=
STRIPE_PRICE_COLLECTOR_MONTHLY=
STRIPE_PRICE_COLLECTOR_YEARLY=
STRIPE_PRICE_GALLERY_MONTHLY=
STRIPE_PRICE_GALLERY_YEARLY=

# Optional: OpenAI, Resend, etc.
# OPENAI_API_KEY=
# RESEND_API_KEY=

# Optional: navbar account menu — browser console logs (also enables with NEXT_PUBLIC_DEBUG_APP=1 for console only)
# NEXT_PUBLIC_ACCOUNT_MENU_DEBUG=1
# Optional: log the same events to Vercel function logs (set on Vercel + use NEXT_PUBLIC_ACCOUNT_MENU_DEBUG=1 on the client build)
# ACCOUNT_MENU_DEBUG=1
