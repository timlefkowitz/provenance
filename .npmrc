dedupe-peer-dependents=true
use-lockfile-v6=true
resolution-mode=highest
package-manager-strict=false
# Allow `pnpm add <pkg>` from the workspace root without -w.
# The provence-app at root is the deployable Next.js project, so root-level
# adds are intentional rather than accidental.
ignore-workspace-root-check=true
public-hoist-pattern[]=*i18next*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*zod*
# Network retry settings for Vercel builds
fetch-retries=5
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
fetch-timeout=300000
network-concurrency=16

